# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Shell scripts
*.sh text eol=lf

# Windows specific
*.bat text eol=crlf
*.cmd text eol=crlf
*.exe binary
*.dll binary

# Python
*.py text eol=lf
*.pyx text eol=lf
*.pxd text eol=lf
*.pxi text eol=lf

# JavaScript/TypeScript
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf

# SQL
*.sql text eol=lf

# Documentation
*.md text eol=lf
*.markdown text eol=lf
*.txt text eol=lf

# Docker
Dockerfile text eol=lf
docker-compose.yml text eol=lf
.dockerignore text eol=lf

# YAML/Config
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
