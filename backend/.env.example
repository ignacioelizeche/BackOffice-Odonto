# Database Configuration
DATABASE_URL=postgresql+psycopg://admin:password@192.168.2.200:5432/backoffice_odonto
SQLALCHEMY_ECHO=False

# Server Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# Security
SECRET_KEY=your_super_secret_key_change_in_production_12345678901234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost,http://localhost:40013,http://127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx

# Email Configuration (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SENDER_EMAIL=noreply@dentalcarepro.com
SENDER_NAME=DentalCare Pro
